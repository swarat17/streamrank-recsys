# PySpark / Java (Windows — update paths to match your installation)
JAVA_HOME=C:\Program Files\Java\jre1.8.0_481
HADOOP_HOME=C:\hadoop
# Must point to the venv Python so Spark workers don't hit the Windows Store alias
PYSPARK_PYTHON=.venv\Scripts\python.exe
PYSPARK_DRIVER_PYTHON=.venv\Scripts\python.exe

# HuggingFace
HF_TOKEN=your_huggingface_token_here

# Kafka
KAFKA_BOOTSTRAP_SERVERS=localhost:9092

# Redis
REDIS_HOST=localhost
REDIS_PORT=6379

# Elasticsearch
ES_HOST=http://localhost:9200

# MLflow
MLFLOW_TRACKING_URI=http://localhost:5000

# FastAPI
API_HOST=0.0.0.0
API_PORT=8000

# Model paths
CF_MODEL_URI=models:/collaborative-filter/Production
RANKER_MODEL_URI=models:/xgboost-ranker/Production
ITEM_EMBEDDINGS_PATH=models/item_embeddings.pkl
PROJECTION_MATRIX_PATH=models/projection_matrix.pkl
